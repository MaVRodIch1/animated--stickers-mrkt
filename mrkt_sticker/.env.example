# Telegram Bot Token (get from @BotFather / получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_token_here

# Your Telegram User ID (get from @userinfobot / узнать у @userinfobot)
OWNER_USER_ID=your_id_here

# MRKT Contest API Key (request from MRKT team)
# Endpoint: https://contest.tgmrkt.io
# Sent as "X-CONTEST-KEY" header.
MRKT_CONTEST_KEY=your_contest_key_here

# Dune Analytics API Key (get from https://dune.com/settings/api)
DUNE_API_KEY=your_key_here

# Telegram MTProto API credentials (optional, only for find_gift_ids.py --mtproto)
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
